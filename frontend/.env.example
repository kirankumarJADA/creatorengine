# ════════════════════════════════════════════════════════════════════
# CreatorEngine Frontend — Environment Variables
# Copy to .env (dev) or set in Vercel project settings (prod).
#
# All client-exposed variables MUST be prefixed with VITE_ — Vite
# refuses to bundle non-VITE_ vars (security feature).
# ════════════════════════════════════════════════════════════════════

# ─── Dev server ───────────────────────────────────────────
VITE_PORT=5173

# ─── API base URL ─────────────────────────────────────────
# Base URL the SPA uses for backend requests.
# Local dev: leave as default; vite proxies /api → backend on 8080.
# Production (Vercel): set to your Render backend URL, e.g.
#   VITE_API_BASE_URL=https://creatorengine-backend.onrender.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# ─── Dev-only proxy target ────────────────────────────────
# Used by vite.config.js during `npm run dev`. Ignored in production.
VITE_API_PROXY_TARGET=http://localhost:8080

# ─── App metadata ─────────────────────────────────────────
VITE_APP_NAME=CreatorEngine
