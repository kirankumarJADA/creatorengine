# ════════════════════════════════════════════════════════════════════
# CreatorEngine Backend — Environment Variables
# Copy to .env (dev) or set in your platform's secret manager (prod).
#
# ⚠️  Production note: every value marked [REQUIRED IN PROD] is
# validated by EnvironmentValidator at startup when
# SPRING_PROFILES_ACTIVE=prod. Boot fails with a clear error list
# if anything is missing or holds a placeholder.
# ════════════════════════════════════════════════════════════════════

# ─── Spring profile ──────────────────────────────────────
# dev   → relaxed CORS, debug logging, no env validator
# prod  → strict CORS, masked errors, env validation runs
SPRING_PROFILES_ACTIVE=dev

# ─── Server port ─────────────────────────────────────────
# Render injects PORT automatically. SERVER_PORT is for self-hosting.
SERVER_PORT=8080

APP_NAME=CreatorEngine

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# [REQUIRED IN PROD] — must contain no localhost entries, must include scheme.
# Example (prod): https://yourapp.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── JWT ──────────────────────────────────────────────────
# [REQUIRED IN PROD] Generate with: openssl rand -base64 64
# Must be ≥ 32 bytes after decoding (256 bits for HMAC-SHA256).
JWT_SECRET=replace-me-with-a-long-base64-secret
JWT_ISSUER=creatorengine
JWT_ACCESS_EXPIRATION_MS=900000        # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000    # 7 days

# ─── Firebase ─────────────────────────────────────────────
# [REQUIRED IN PROD]
FIREBASE_PROJECT_ID=your-firebase-project-id

# [REQUIRED IN PROD] — from Firebase console → Project settings → General
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Provide EXACTLY ONE of the two below.
# (a) Path to a service-account JSON file (local dev)
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
# (b) Inline JSON blob (prod — paste the entire JSON as a single line)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"…",…}

# Redirect link in Firebase-generated password-reset emails.
# [REQUIRED IN PROD] — must be HTTPS, not localhost
FIREBASE_PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/login

# ─── Frontend ─────────────────────────────────────────────
# Where backend bounces the browser back to the SPA.
# [REQUIRED IN PROD] — must be HTTPS, not localhost
FRONTEND_BASE_URL=http://localhost:5173

# ─── Meta / Instagram ─────────────────────────────────────
# From developers.facebook.com → your app → Settings → Basic.
# [REQUIRED IN PROD]
META_APP_ID=
META_APP_SECRET=

# Token Meta echoes during webhook verification handshake.
# [REQUIRED IN PROD] — use a high-entropy string (≥16 chars).
# Generate with: openssl rand -hex 32
META_VERIFY_TOKEN=change-me-meta-verify-token

# OAuth redirect URI registered in your Meta app.
# [REQUIRED IN PROD] — MUST be HTTPS, not localhost.
# Example: https://your-backend.onrender.com/api/instagram/callback
META_REDIRECT_URI=http://localhost:8080/api/instagram/callback

# Where the backend sends the user after OAuth completes.
# [REQUIRED IN PROD] — MUST be HTTPS, not localhost.
# Example: https://yourapp.vercel.app/instagram/callback
META_SUCCESS_REDIRECT_URI=http://localhost:5173/instagram/callback

# Graph API version. Bump as Meta releases new versions.
META_GRAPH_API_VERSION=v19.0

# ─── AI Message Assistant (optional) ──────────────────────
# Used by POST /api/ai/generate-message to suggest DM templates.
# Leave OPENAI_API_KEY blank to use the template-based fallback
# generator (still produces 3 usable suggestions, just not LLM-quality).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=20000
